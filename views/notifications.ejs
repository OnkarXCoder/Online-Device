<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Notifications | TechFix</title>
<style>
*{ margin:0; padding:0; box-sizing:border-box; font-family:'Segoe UI',sans-serif; }
body{ background:#f4f6f9; padding:40px; }
h2{ margin-bottom:30px; }
.card{
  background:white; padding:20px; border-radius:12px;
  box-shadow:0 10px 25px rgba(0,0,0,0.08); margin-bottom:20px;
}
.card p{ margin-bottom:8px; }
.pay-btn{
  background:#ff9900; border:none; padding:8px 16px;
  border-radius:6px; cursor:pointer; font-weight:bold;
  text-decoration:none; display:inline-block; color:black;
}
.pay-btn:hover{ background:#e68a00; }
.empty{ color:#777; text-align:center; padding:40px; }
.back{ display:inline-block; margin-top:20px; color:#ff9900; text-decoration:none; }
</style>
</head>
<body>
<h2>Notifications</h2>
<% if(repairs.length === 0){ %>
  <p class="empty">No pending payment notifications</p>
<% } else { %>
  <% repairs.forEach(function(r){ %>
    <div class="card">
      <p><strong>Device:</strong> <%= r.deviceType %> - <%= r.brand %> <%= r.model %></p>
      <p><strong>Issue:</strong> <%= r.issue %></p>
      <p><strong>Amount:</strong> ₹<%= r.amount %></p>
      <p><strong>Status:</strong> <%= r.status %></p>
      <a href="/repair-checkout/<%= r._id %>" class="pay-btn">Pay Now</a>
    </div>
  <% }) %>
<% } %>
<a href="/" class="back">⬅ Back to Home</a>
</body>
</html>
