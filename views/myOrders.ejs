<!DOCTYPE html>

<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>My Orders | Snehpreet Enterprises</title>

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

body{
font-family:'Segoe UI',sans-serif;
background:#f4f6f9;
margin:0;
padding:0;
}

/* NAVBAR */

.navbar{
background:#131921;
padding:15px 30px;
display:flex;
justify-content:space-between;
align-items:center;
}

.logo{
color:#ff9900;
font-size:22px;
font-weight:bold;
}

.nav-links a{
color:white;
margin-left:15px;
text-decoration:none;
}

.nav-links a:hover{
color:#ff9900;
}

/* PAGE */

.container{
max-width:1000px;
margin:40px auto;
padding:20px;
}

h2{
text-align:center;
margin-bottom:30px;
}

/* ORDER CARD */

.order-card{

background:white;
padding:20px;
border-radius:10px;
box-shadow:0 10px 25px rgba(0,0,0,0.1);
margin-bottom:20px;

}

.order-header{

display:flex;
justify-content:space-between;
margin-bottom:10px;

}

.total{
color:#ff9900;
font-weight:bold;
}

.product{

display:flex;
align-items:center;
margin:10px 0;
border-top:1px solid #eee;
padding-top:10px;

}

.product img{

width:60px;
height:60px;
object-fit:cover;
border-radius:6px;
margin-right:10px;

}

.status{

background:#28a745;
color:white;
padding:4px 8px;
border-radius:4px;
font-size:12px;

}

.empty{
text-align:center;
color:#777;
margin-top:40px;
}

</style>

</head>

<body>

<div class="navbar">

<div class="logo">Snehpreet Enterprises</div>

<div class="nav-links">

<a href="/">Home</a> <a href="/cart">Cart</a> <a href="/logout">Logout</a>

</div>

</div>

<div class="container">

<h2>My Orders</h2>

<% if(orders.length === 0){ %>

<p class="empty">You have not placed any orders yet.</p>

<% } %>

<% orders.forEach(function(order){ %>

<div class="order-card">

<div class="order-header">

<div>
<strong>Order Date:</strong>
<%= new Date(order.createdAt).toLocaleDateString() %>
</div>

<div class="total">
₹<%= order.total %>
</div>

</div>

<p>
Status:
<span class="status"><%= order.paymentStatus %></span>
</p>

<% order.products.forEach(function(product){ %>

<div class="product">

<img src="<%= product.image %>">

<div>

<strong><%= product.name %></strong><br>

₹<%= product.price %>

</div>

</div>

<% }) %>

</div>

<% }) %>

</div>

</body>
</html>
