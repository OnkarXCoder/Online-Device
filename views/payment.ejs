<!DOCTYPE html>
<html>
<head>
  <title>Payment</title>

  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>

  <style>
    body{
      font-family: Arial;
      background:#f4f6f9;
      display:flex;
      justify-content:center;
      align-items:center;
      height:100vh;
    }

    .box{
      background:white;
      padding:30px;
      border-radius:10px;
      box-shadow:0 10px 25px rgba(0,0,0,0.1);
      text-align:center;
      width:350px;
    }

    h2{
      color:#ff9900;
      margin-bottom:10px;
    }

    button{
      background:#ff9900;
      border:none;
      padding:12px 20px;
      border-radius:6px;
      cursor:pointer;
      font-size:16px;
      margin-top:15px;
      width:100%;
    }

    button:hover{
      background:#e68a00;
    }
  </style>

</head>

<body>

<div class="box">

  <h2>Complete Payment</h2>

  <p>Amount: ₹<%= amount %></p>

  <!-- 🔥 IMPORTANT (Repair Support) -->
  <input type="hidden" id="repairId" value="<%= repairId %>">
  <button onclick="payNow()">Pay Now</button>

</div>
<script>
const paymentType = "<%= type || 'product' %>";  // ✅ default product
const repairId = "<%= repairId || '' %>";

console.log("PAYMENT TYPE:", paymentType);

var options = {
    key: "<%= key %>",
    amount: "<%= amount * 100 %>",
    currency: "INR",
    name: "TechFix",
    description: "Payment",

    order_id: "<%= orderId %>",

    handler: function (response){

        fetch("/payment-success",{
            method:"POST",
            headers:{
                "Content-Type":"application/json"
            },
            body: JSON.stringify({
                paymentId: response.razorpay_payment_id,
                repairId: paymentType === "repair" ? repairId : null
            })
        })
        .then(res=>res.json())
        .then(data=>{

            // ✅ FINAL REDIRECTION LOGIC
            if(paymentType === "repair"){
                window.location.href = "/my-repairs";
            }else{
                window.location.href = "/order-success"; // or "/cart"
            }

        });

    }
};

var rzp = new Razorpay(options);

function payNow(){
    rzp.open();
}
</script>

</body>
</html>