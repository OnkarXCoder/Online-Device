<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Your Cart | TechFix</title>

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:'Segoe UI',sans-serif;
}

body{
  background:#f4f6f9;
}

/* NAVBAR */
.navbar{
  background:#0f1111;
  padding:18px 80px;
  display:flex;
  justify-content:space-between;
  align-items:center;
  color:white;
}
.logo{
  color:#ff9900;
  font-size:24px;
  font-weight:700;
}
.navbar a{
  color:white;
  text-decoration:none;
  margin-left:20px;
}
.navbar a:hover{
  color:#ff9900;
}

/* MAIN CONTAINER */
.container{
  display:grid;
  grid-template-columns:2fr 1fr;
  gap:30px;
  padding:60px 80px;
}

/* CART ITEMS */
.cart-item{
  background:white;
  padding:20px;
  border-radius:15px;
  display:flex;
  gap:20px;
  align-items:center;
  margin-bottom:20px;
  box-shadow:0 10px 25px rgba(0,0,0,0.08);
  transition:0.3s;
}
.cart-item:hover{
  transform:translateY(-5px);
  box-shadow:0 15px 35px rgba(0,0,0,0.15);
}

.cart-item img{
  width:120px;
  height:100px;
  object-fit:cover;
  border-radius:10px;
}

.item-info{
  flex:1;
}

.item-info h3{
  margin-bottom:8px;
}

.price{
  color:#ff9900;
  font-weight:700;
  margin-bottom:8px;
}

.remove-btn{
  background:#ff4d4d;
  color:white;
  border:none;
  padding:8px 14px;
  border-radius:6px;
  cursor:pointer;
  transition:0.3s;
}
.remove-btn:hover{
  background:#cc0000;
}

/* SUMMARY BOX */
.summary{
  background:white;
  padding:30px;
  border-radius:15px;
  box-shadow:0 10px 25px rgba(0,0,0,0.1);
  height:fit-content;
}

.summary h3{
  margin-bottom:20px;
}

.total{
  font-size:22px;
  font-weight:bold;
  margin:15px 0;
  color:#ff9900;
}

.checkout-btn{
  width:100%;
  padding:12px;
  background:#ff9900;
  border:none;
  border-radius:8px;
  font-weight:600;
  cursor:pointer;
  transition:0.3s;
}
.checkout-btn:hover{
  background:#e68a00;
}

.empty{
  text-align:center;
  padding:100px;
  font-size:18px;
}

/* RESPONSIVE */
@media(max-width:900px){
  .container{
    grid-template-columns:1fr;
    padding:40px 20px;
  }
}
</style>
</head>
<body>

<!-- NAVBAR -->
<div class="navbar">
  <div class="logo">Snehpreet Enterprises</div>
  <div>
    <a href="/">Home</a>
    <a href="/cart">🛒 Cart (<%= cartCount %>)</a>
    <a href="/logout">Logout</a>
  </div>
</div>

<h2 style="padding:40px 80px 0;">Your Shopping Cart</h2>

<% if(cart.length === 0){ %>

  <div class="empty">
    🛒 Your cart is empty.<br><br>
    <a href="/" style="color:#ff9900;text-decoration:none;">Continue Shopping</a>
  </div>

<% } else { %>

<div class="container">

  <!-- LEFT SIDE: ITEMS -->
  <div>
    <% cart.forEach(function(item, index){ %>
      <div class="cart-item">
        <img src="<%= item.image %>" alt="product">

        <div class="item-info">
          <h3><%= item.name %></h3>
          <div class="price">₹<%= item.price %></div>

         <form method="POST" action="/remove-from-cart/<%= item._id %>">
            <button type="submit" style="
            background:#ff4d4d;
            color:white;
            border:none;
            padding:8px 15px;
            border-radius:6px;
            cursor:pointer;
            margin-top:8px;">
            Remove
            </button>
            </form>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- RIGHT SIDE: SUMMARY -->
  <div class="summary">
    <h3>Order Summary</h3>
    <p>Total Items: <strong><%= cart.length %></strong></p>
    <div class="total">
      Total: ₹<%= total %>
    </div>
    <form method="POST" action="/checkout">
    <button class="checkout-btn">Proceed to Checkout</button>
    </form> 
   </div>

</div>

<% } %>

</body>
</html>