<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Edit Product | TechFix Admin</title>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Segoe UI',sans-serif;
}

/* BACKGROUND */

body{
min-height:100vh;
display:flex;
justify-content:center;
align-items:center;
background:linear-gradient(135deg,#0f172a,#1e293b);
padding:30px;
}

/* CARD */

.box{
background:rgba(255,255,255,0.95);
padding:40px;
border-radius:16px;
width:460px;
box-shadow:0 20px 50px rgba(0,0,0,0.4);
backdrop-filter:blur(10px);
}

/* HEADER */

h2{
text-align:center;
margin-bottom:25px;
color:#111827;
}

/* LABEL */

label{
font-size:13px;
font-weight:600;
color:#444;
display:block;
margin-bottom:6px;
}

/* INPUT */

input, textarea{
width:100%;
padding:11px;
border-radius:8px;
border:1px solid #ddd;
margin-bottom:16px;
font-size:14px;
transition:0.25s;
}

input:focus, textarea:focus{
border-color:#ff9900;
outline:none;
box-shadow:0 0 0 2px rgba(255,153,0,0.2);
}

textarea{
resize:none;
height:90px;
}

/* INPUT ICON */

.input-icon{
position:relative;
}

.input-icon i{
position:absolute;
left:10px;
top:12px;
color:#999;
}

.input-icon input{
padding-left:32px;
}

/* BUTTONS */

.btn-group{
display:flex;
gap:10px;
}

.update-btn{
flex:1;
background:linear-gradient(135deg,#ff9900,#ff7a00);
border:none;
padding:12px;
border-radius:10px;
color:white;
font-weight:bold;
cursor:pointer;
transition:0.3s;
}

.update-btn:hover{
transform:translateY(-2px);
box-shadow:0 8px 20px rgba(255,153,0,0.4);
}

.cancel-btn{
flex:1;
background:#e5e7eb;
border:none;
padding:12px;
border-radius:10px;
cursor:pointer;
font-weight:bold;
}

.cancel-btn:hover{
background:#d1d5db;
}

/* PRODUCT PREVIEW */

.preview{
width:100%;
height:180px;
border-radius:10px;
object-fit:cover;
margin-bottom:20px;
border:1px solid #eee;
}

/* MOBILE */

@media(max-width:520px){

.box{
width:100%;
padding:25px;
}

}

</style>
</head>

<body>

<div class="box">

<h2><i class="fa fa-pen-to-square"></i> Edit Product</h2>

<!-- PRODUCT IMAGE -->

<% if(product.image){ %>
<img src="<%= product.image %>" class="preview">
<% } %>

<form method="POST" action="/admin-update-product/<%= product._id %>">

<label>Product Name</label>

<div class="input-icon">
<i class="fa fa-box"></i>
<input type="text" name="name" value="<%= product.name %>" required>
</div>

<label>Price</label>

<div class="input-icon">
<i class="fa fa-indian-rupee-sign"></i>
<input type="number" name="price" value="<%= product.price %>" required>
</div>

<label>Stock</label>

<div class="input-icon">
<i class="fa fa-cubes"></i>
<input type="number" name="stock" value="<%= product.stock %>" required>
</div>

<label>Description</label>
<textarea name="description"><%= product.description %></textarea>

<div class="btn-group">

<button class="update-btn">
<i class="fa fa-save"></i> Update Product
</button>

<button type="button" class="cancel-btn" onclick="window.location='/admin-dashboard'">
Cancel
</button>

</div>

</form>

</div>

</body>
</html>