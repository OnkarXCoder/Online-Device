<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Repair Payment | TechFix</title>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<style>
*{ margin:0; padding:0; box-sizing:border-box; font-family:'Segoe UI',sans-serif; }
body{ background:#f4f6f9; display:flex; justify-content:center; align-items:center; min-height:100vh; }
.box{ background:white; padding:30px; border-radius:12px; box-shadow:0 10px 25px rgba(0,0,0,0.1); width:400px; }
h2{ color:#ff9900; margin-bottom:20px; }
.info{ margin-bottom:15px; line-height:1.8; }
.info strong{ display:inline-block; width:100px; }
.pay-btn{
  background:#ff9900; border:none; padding:12px; width:100%;
  border-radius:6px; cursor:pointer; font-size:16px; font-weight:bold;
}
.pay-btn:hover{ background:#e68a00; }
.error{ color:red; margin-bottom:10px; }
</style>
</head>
<body>
<div class="box">
<h2>Repair Payment</h2>
<% if(!repair){ %>
  <p class="error">Repair not found</p>
  <a href="/my-repairs" style="color:#ff9900;">⬅ Back to My Repairs</a>
<% } else { %>
  <div class="info">
    <p><strong>Device:</strong> <%= repair.deviceType %></p>
    <p><strong>Brand:</strong> <%= repair.brand %></p>
    <p><strong>Model:</strong> <%= repair.model %></p>
    <p><strong>Issue:</strong> <%= repair.issue %></p>
    <p><strong>Amount:</strong> ₹<%= repair.amount %></p>
    <p><strong>Status:</strong> <%= repair.status %></p>
  </div>
  <form method="POST" action="/repair-payment-success/<%= repair._id %>">
    <button type="submit" class="pay-btn">Mark as Paid</button>
  </form>
<% } %>
</div>
</body>
</html>
