<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Admin Dashboard | TechFix</title>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Segoe UI',sans-serif;
}

body{
display:flex;
background:#f1f5f9;
min-height:100vh;
}

/* SIDEBAR */

.sidebar{
width:250px;
background:#0f172a;
color:white;
padding:30px 20px;
position:fixed;
height:100%;
}

.sidebar h2{
color:#ff9900;
margin-bottom:40px;
}

.sidebar a{
display:flex;
align-items:center;
gap:10px;
color:white;
text-decoration:none;
padding:12px;
border-radius:8px;
margin-bottom:10px;
transition:0.3s;
font-size:14px;
}

.sidebar a:hover{
background:#ff9900;
color:black;
}

/* MAIN */

.main{
margin-left:250px;
padding:40px;
width:100%;
}

/* HEADER */

.header{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:30px;
}

.header h1{
font-size:26px;
font-weight:600;
}

.admin{
background:#111827;
color:white;
padding:8px 14px;
border-radius:6px;
font-size:14px;
}

/* DASHBOARD CARDS */

.dashboard-cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:20px;
margin-bottom:40px;
}

.stat-card{
background:white;
padding:25px;
border-radius:12px;
box-shadow:0 10px 25px rgba(0,0,0,0.08);
transition:0.3s;
}

.stat-card:hover{
transform:translateY(-5px);
}

.stat-card h3{
color:#64748b;
margin-bottom:10px;
}

.stat-card h2{
font-size:30px;
color:#111827;
}

/* SECTION */

.section{
margin-bottom:50px;
}

.section h2{
margin-bottom:20px;
font-weight:600;
}

/* SEARCH */

.search-box{
margin-bottom:20px;
}

.search-box input{
padding:10px 15px;
width:300px;
border-radius:8px;
border:1px solid #d1d5db;
outline:none;
}

/* TABLE */

table{
width:100%;
border-collapse:collapse;
background:white;
border-radius:10px;
overflow:hidden;
box-shadow:0 10px 25px rgba(0,0,0,0.08);
}

th{
background:#111827;
color:white;
padding:14px;
font-weight:500;
}

td{
padding:14px;
border-bottom:1px solid #f1f5f9;
}

tr:hover{
background:#f9fafb;
}

.low-stock{
color:red;
font-weight:600;
}

/* BUTTONS */

button{
padding:7px 14px;
border:none;
border-radius:6px;
cursor:pointer;
font-size:13px;
transition:0.2s;
}

button:hover{
opacity:0.9;
}

.update-btn{
background:#ff9900;
color:black;
}

.delete-btn{
background:#ef4444;
color:white;
}

.edit-btn{
background:#2563eb;
color:white;
padding:6px 12px;
border-radius:6px;
text-decoration:none;
margin-right:6px;
}

/* REPAIR GRID */

.repair-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(360px,1fr));
gap:25px;
}

.repair-card{
background:white;
padding:22px;
border-radius:12px;
box-shadow:0 15px 35px rgba(0,0,0,0.08);
transition:0.3s;
}

.repair-card:hover{
transform:translateY(-4px);
}

.repair-top{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:15px;
}

.device-badge{
background:#eef2ff;
padding:6px 10px;
border-radius:6px;
font-size:12px;
font-weight:500;
}

.email{
font-size:13px;
color:#6b7280;
}

.issue-box{
background:#f3f4f6;
padding:12px;
border-radius:6px;
margin:12px 0;
}

/* PROGRESS */

.progress-container{
margin:18px 0;
}

.progress-bar{
display:flex;
justify-content:space-between;
position:relative;
margin-top:10px;
}

.progress-bar::before{
content:"";
position:absolute;
top:8px;
left:0;
right:0;
height:4px;
background:#e5e7eb;
z-index:0;
}

.progress-step{
width:18px;
height:18px;
border-radius:50%;
background:white;
border:3px solid #e5e7eb;
z-index:1;
}

.progress-step.active{
background:#ff9900;
border-color:#ff9900;
}

.progress-labels{
display:flex;
justify-content:space-between;
font-size:12px;
margin-top:6px;
color:#6b7280;
}

/* STATUS */

.status-checkboxes{
display:flex;
flex-wrap:wrap;
gap:12px;
font-size:14px;
margin-top:5px;
}

.status-checkboxes input{
margin-right:4px;
}

/* DATE */

input[type="date"]{
padding:8px;
border-radius:6px;
border:1px solid #d1d5db;
margin-top:6px;
}

/* BUTTON GROUP */

.btn-group{
display:flex;
gap:10px;
margin-top:12px;
}
/* Notification Wrapper */

.notification-wrapper{
position:relative;
}

/* Bell */

.notification-bell{
font-size:20px;
cursor:pointer;
position:relative;
color:#111;
}

/* Notification Count */

.notify-count{
position:absolute;
top:-6px;
right:-10px;
background:#ff4d4d;
color:white;
font-size:11px;
padding:3px 6px;
border-radius:50%;
}

/* Dropdown */

.notify-dropdown{

display:none;

position:absolute;
right:0;
top:35px;

width:320px;

background:white;
border-radius:12px;

box-shadow:0 10px 40px rgba(0,0,0,0.15);

padding:15px;

z-index:999;

}

/* Title */

.notify-dropdown h4{
margin-bottom:12px;
}

/* Item */

.notify-item{

border-bottom:1px solid #eee;

padding:12px 0;

display:flex;
justify-content:space-between;
align-items:center;

}

/* Issue text */

.notify-info p{
font-size:13px;
color:#666;
}

/* Buttons */

.notify-actions{
display:flex;
gap:6px;
}

.repair-card{
background:white;
padding:20px;
border-radius:14px;
box-shadow:0 10px 30px rgba(0,0,0,0.08);
transition:0.3s;
}

.repair-card:hover{
transform:translateY(-5px);
}

/* HEADER */
.repair-header{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:10px;
}

/* INFO */
.repair-info{
margin-top:10px;
line-height:1.6;
}

/* PRICE */
.price-box{
margin-top:15px;
}

.price-box form{
display:flex;
gap:10px;
}

.price-box input{
flex:1;
padding:8px;
border-radius:6px;
border:1px solid #ccc;
}

.price-box button{
background:#ff9900;
border:none;
padding:8px 12px;
border-radius:6px;
cursor:pointer;
font-weight:bold;
}

/* BADGES */
.badge{
padding:6px 12px;
border-radius:20px;
color:white;
font-size:12px;
font-weight:600;
}

.green{background:#28a745;}
.orange{background:#ff9900;}
.blue{background:#007bff;}
.gray{background:#6c757d;}

.status-row{
display:flex;
gap:10px;
margin-top:12px;
}

/* ISSUE */
.issue-box{
background:#f3f4f6;
padding:10px;
border-radius:8px;
margin-top:15px;
}

/* DATE */
.date{
font-size:12px;
color:#666;
margin-top:10px;
}

/* DEVICE */
.device-badge{
background:#eef2ff;
padding:5px 10px;
border-radius:6px;
font-size:12px;
}

.accept-btn{

background:#ff9900;
border:none;
padding:6px 12px;
border-radius:6px;
cursor:pointer;
font-size:12px;

}

.action-buttons{
display:flex;
gap:12px;   /* space between buttons */
margin-top:15px;
}

.update-btn{
background:#ff9900;
color:black;
padding:10px 16px;
border-radius:8px;
border:none;
cursor:pointer;
font-weight:600;
}

.delete-btn{
background:#ef4444;
color:white;
padding:10px 16px;
border-radius:8px;
border:none;
cursor:pointer;
font-weight:600;
}

.update-btn:hover{
background:#e68a00;
}

.delete-btn:hover{
background:#dc2626;
}

.reject-btn{

background:#ef4444;
color:white;
border:none;
padding:6px 12px;
border-radius:6px;
cursor:pointer;
font-size:12px;

}
.status {
color:white;
padding:5px 10px;
border-radius:6px;
}

.status.approved {
background:#28a745;
}

.status.default {
background:#555;
}
/* Empty */

.empty{
font-size:13px;
color:#777;
}
</style>

</head>

<body>

<div class="sidebar">

<h2>TechFix</h2>

<a href="/admin-dashboard"><i class="fa fa-chart-line"></i> Dashboard</a>
<a href="/admin-add-product"><i class="fa fa-plus"></i> Add Product</a>
<a href="/"><i class="fa fa-globe"></i> Website</a>
<a href="/logout"><i class="fa fa-sign-out-alt"></i> Logout</a>

</div>

<div class="main">

<div class="header">

<h1>Admin Dashboard</h1>

<div style="display:flex;align-items:center;gap:20px;">

<!-- Notification Bell -->

<div class="notification-wrapper">

<div class="notification-bell" onclick="toggleNotify()">

<i class="fa fa-bell"></i>

<span class="notify-count">
<%= repairs.filter(r => r.status === "Requested").length %>
</span>

</div>

<div class="notify-dropdown" id="notifyDropdown">

<h4>New Repair Requests</h4>

<% const newRequests = repairs.filter(r => r.status === "Requested"); %>

<% if(newRequests.length === 0){ %>

<p class="empty">No new repair requests</p>

<% } else { %>

<% newRequests.forEach(function(r){ %>

<div class="notify-item">

<div class="notify-info">

<strong><%= r.deviceType %></strong>
<p><%= r.issue %></p>

</div>

<div class="notify-actions">

<form method="POST" action="/accept-repair/<%= r._id %>">
<button class="accept-btn">Accept</button>
</form>

<form method="POST" action="/delete-repair/<%= r._id %>">
<button class="reject-btn">Reject</button>
</form>

</div>

</div>

<% }) %>

<% } %>

</div>

</div>
<div class="admin">Admin Panel</div>

</div>

</div>
<!-- STATS -->

<div class="dashboard-cards">

<div class="stat-card">
<h3>Total Users</h3>
<h2><%= totalUsers %></h2>
</div>

<div class="stat-card">
<h3>Total Products</h3>
<h2><%= totalProducts %></h2>
</div>

<div class="stat-card">
<h3>Total Repairs</h3>
<h2><%= totalRepairs %></h2>
</div>

</div>

<!-- PRODUCTS -->

<div class="section">

<h2>🛒 Manage Products</h2>

<div class="search-box">
<input type="text" id="productSearch" placeholder="Search product...">
</div>

<% if(products.length === 0){ %>

<p>No Products Found</p>

<% } else { %>

<table id="productTable">

<thead>
<tr>
<th>Name</th>
<th>Price</th>
<th>Stock</th>
<th>Action</th>
</tr>
</thead>

<tbody>

<% products.forEach(function(p){ %>

<tr>

<td><%= p.name %></td>

<td>₹<%= p.price %></td>

<td>
<% if(p.stock <= 5){ %>
<span class="low-stock"><%= p.stock %> (Low)</span>
<% } else { %>
<%= p.stock %>
<% } %>
</td>

<td>

<a href="/admin-edit-product/<%= p._id %>" class="edit-btn">Edit</a>

<form method="POST" action="/delete-product/<%= p._id %>" style="display:inline;">
<button class="delete-btn">Delete</button>
</form>

</td>

</tr>

<% }) %>

</tbody>

</table>

<% } %>

</div>
<!-- ================= CUSTOMER ORDERS ================= -->

<div class="section">

<h2>📦 Customer Orders</h2>

<% if(orders.length === 0){ %>

<p>No Orders Found</p>

<% } else { %>

<table>

<thead>
<tr>
<th>Customer</th>
<th>Email</th>
<th>Products</th>
<th>Total</th>
<th>Payment</th>
<th>Date</th>
</tr>
</thead>

<tbody>

<% orders.forEach(function(order){ %>

<tr>

<td><%= order.name %></td>

<td><%= order.email %></td>

<td>

<% order.products.forEach(function(p){ %>

<p><%= p.name %> - ₹<%= p.price %></p>

<% }) %>

</td>

<td>₹<%= order.total %></td>

<td><%= order.paymentStatus %></td>

<td><%= new Date(order.createdAt).toLocaleDateString() %></td>

</tr>

<% }) %>

</tbody>

</table>

<% } %>

</div>

<!-- REPAIR -->

<div class="section">

<h2>🔧 Repair Requests</h2>

<% if(repairs.length === 0){ %>

<p>No Repair Requests Found</p>

<% } else { %>

<div class="repair-grid">

<% repairs.forEach(function(r){ %>

<div class="repair-card">

<!-- HEADER -->
<div class="repair-header">
<div>
<h3><%= r.name %></h3>
<p class="email"><%= r.email %></p>
</div>

<span class="device-badge"><%= r.deviceType %></span>
</div>

<!-- INFO -->
<div class="repair-info">
<p><strong>Brand:</strong> <%= r.brand %></p>
<p><strong>Model:</strong> <%= r.model %></p>
<p><strong>Problem:</strong> <%= r.problemType %></p>
<p><strong>Urgency:</strong> <%= r.urgency %></p>
<p><strong>Phone:</strong> <%= r.phone %></p>
<p><strong>Pickup:</strong> <%= r.pickupRequired %></p>
</div>

<!-- PRICE -->
<div class="price-box">
<form action="/set-repair-price/<%= r._id %>" method="POST">
<input type="number" name="amount" placeholder="₹ Enter Amount" required>
<button type="submit">Send</button>
</form>
</div>

<!-- STATUS + PAYMENT -->
<div class="status-row">

<span class="badge 
<%= r.status === 'Approved' ? 'green' :
    r.status === 'Waiting for Payment' ? 'orange' :
    r.status === 'In Progress' ? 'blue' :
    r.status === 'Completed' ? 'green' :
    'gray' %>">
<%= r.status %>
</span>

<span class="badge 
<%= r.paymentStatus === 'Paid' ? 'blue' :
    r.paymentStatus === 'Pay Later' ? 'green' :
    'orange' %>">
<%= r.paymentStatus %>
</span>

</div>

<!-- ISSUE -->
<div class="issue-box">
<strong>Issue:</strong>
<p><%= r.issue %></p>
</div>

<!-- DATE -->
<p class="date">
Received: <%= r.createdAt ? new Date(r.createdAt).toLocaleDateString() : "N/A" %>
</p>

<!-- PROGRESS -->
<div class="progress-container">

<div class="progress-bar">

<div class="progress-step <%= r.status==='Pending'?'active':'' %>"></div>
<div class="progress-step <%= r.status==='In Progress'||r.status==='Completed'||r.status==='Ready for Pickup'?'active':'' %>"></div>
<div class="progress-step <%= r.status==='Completed'||r.status==='Ready for Pickup'?'active':'' %>"></div>
<div class="progress-step <%= r.status==='Ready for Pickup'?'active':'' %>"></div>

</div>

<div class="progress-labels">
<span>Pending</span>
<span>Progress</span>
<span>Completed</span>
<span>Ready</span>
</div>

</div>

<!-- STATUS UPDATE -->
<form method="POST" action="/update-status/<%= r._id %>">

<div class="status-checkboxes">

<label><input type="radio" name="status" value="Pending" <%= r.status==="Pending"?"checked":"" %>> Pending</label>

<label><input type="radio" name="status" value="In Progress" <%= r.status==="In Progress"?"checked":"" %>> Progress</label>

<label><input type="radio" name="status" value="Completed" <%= r.status==="Completed"?"checked":"" %>> Completed</label>

<label><input type="radio" name="status" value="Ready for Pickup" <%= r.status==="Ready for Pickup"?"checked":"" %>> Ready</label>

</div>

<br>

<label>Expected Date</label>
<input type="date" name="expectedDate">

<div class="action-buttons">

<form method="POST" action="/update-status/<%= r._id %>">
<button class="update-btn">Update</button>
</form>

<form method="POST" action="/delete-repair/<%= r._id %>">
<button class="delete-btn">Delete</button>
</form>

</div>
</div>

<% }) %>

</div>

<% } %>

</div>

</div>

<script>

const search = document.getElementById("productSearch");

search.addEventListener("keyup", function(){

const filter = search.value.toLowerCase();

const rows = document.querySelectorAll("#productTable tbody tr");

rows.forEach(function(row){

const text = row.textContent.toLowerCase();

if(text.includes(filter)){
row.style.display = "";
}else{
row.style.display = "none";
}

});

});

</script>
<script>

function toggleNotify(){

const box = document.getElementById("notifyDropdown");

if(box.style.display === "block"){
box.style.display = "none";
}else{
box.style.display = "block";
}

}

</script>

</body>
</html>